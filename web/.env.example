# Copy this file to .env.local (gitignored) and fill in your Firebase project values.
# The VITE_FIREBASE_* values are intentionally public per the Firebase web SDK.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional. Project settings → General → Web app → "Measurement ID" (G-...).
# When set, the client lazy-inits Firebase Analytics (GA4) and emits custom
# events via lib/analytics.ts. Leave blank to skip analytics — every
# trackEvent call no-ops silently.
VITE_FIREBASE_MEASUREMENT_ID=

# Set to 1 to point the client at local Firebase emulators
# (auth:9099, firestore:8080). See firebase.json for emulator ports.
VITE_USE_EMULATOR=0
