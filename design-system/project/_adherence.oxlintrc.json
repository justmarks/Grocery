{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/grocery/**",
              "ui_kits/grocery_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Manrope|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Manrope, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AisleHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|count|key|ref|className|style|children)$/]",
        "message": "<AisleHeader> doesn't accept that prop. Declared props: category, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Brand'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|className|key|ref|className|style|children)$/]",
        "message": "<Brand> doesn't accept that prop. Declared props: variant, size, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Brand'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:lockup|stacked|mark)$/]",
        "message": "<Brand> variant must be one of 'lockup' | 'stacked' | 'mark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|iconFilled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, iconFilled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger|success)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|dot|children|key|ref|className|style|children)$/]",
        "message": "<CategoryTag> doesn't accept that prop. Declared props: category, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|size|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|children|action|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, children, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|children|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, hint, error, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='GroceryItemRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|quantity|category|stores|checked|onToggle|showCategory|trailing|key|ref|className|style|children)$/]",
        "message": "<GroceryItemRow> doesn't accept that prop. Declared props: text, quantity, category, stores, checked, onToggle, showCategory, trailing."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|filled|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, filled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|variant|filled|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, variant, filled."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|danger)$/]",
        "message": "<IconButton> variant must be one of 'default' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModeToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|key|ref|className|style|children)$/]",
        "message": "<ModeToggle> doesn't accept that prop. Declared props: value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModeToggle'] > JSXAttribute[name.name='value'] > Literal[value!=/^(?:plan|shop)$/]",
        "message": "<ModeToggle> value must be one of 'plan' | 'shop'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoreFilter'] > JSXAttribute > JSXIdentifier[name!=/^(?:stores|value|onChange|key|ref|className|style|children)$/]",
        "message": "<StoreFilter> doesn't accept that prop. Declared props: stores, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|visible|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: children, visible."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
